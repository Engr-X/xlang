/*
Stress test for control-flow / branch lowering.
Expected:
1) sum0ToN(20) = 210
2) chooseSum(20) = 1048576 (= 2^20)
3) primeSum(10000) = 5736396
4) condScore(3, 5) = 129
5) loopScore() = 131
*/

fun sum0ToN(n: int) -> int
{
    var s: int = 0

    for (var i: int = 0; i <= n; i++):
        s += i

    return s
}

fun chooseSum(n: int) -> int
{
    var s: int = 0
    var c: int = 1

    for (var k: int = 0; k <= n; k++)
    {
        s += c

        if k < n:
            c = c * (n - k) / (k + 1)
    }

    return s
}

fun isPrime(x: int) -> bool
{
    if x <= 1:
        return false
    if x == 2:
        return true
    if x % 2 == 0:
        return false

    for (var d: int = 3; d * d <= x; d += 2)
    {
        if x % d == 0:
            return false
    }

    return true
}

fun primeSum(limit: int) -> int
{
    var i: int = 2
    var s: int = 0

    while i <= limit
    {
        if isPrime(i):
            s += i

        i++
    }

    return s
}

fun condScore(a: int, b: int) -> int
{
    var s: int = 0

    if a == b: s += 1
    else: s += 10

    if a != b: s += 2
    else: s += 20

    if a < b: s += 3
    else: s += 30

    if a <= b: s += 4
    else: s += 40

    if a > b: s += 5
    else: s += 50

    if a >= b: s += 6
    else: s += 60

    return s
}

fun loopScore() -> int
{
    var s: int = 0

    var x: int = 0
    while x < 3
    {
        s += x
        x++
    }

    for (var i: int = 1; i <= 3; i++):
        s += i
    else:
        s += 100

    repeat 4:
        s += 2
    else:
        s += 7

    var u: int = 0
    until u >= 3:
        u++
    else:
        s += u

    var dw: int = 0
    do:
        dw++
    while dw < 2;
    else:
        s += dw

    var du: int = 0
    do:
        du++
    until du >= 2;
    else:
        s += du

    return s
}

fun main() -> void
{
    val n: int = 20
    val s0: int = sum0ToN(n)
    val csum: int = chooseSum(n)
    val psum: int = primeSum(10000)
    val cs: int = condScore(3, 5)
    val ls: int = loopScore()

    putln("sum0ToN(20):")
    putln(s0)
    putln("chooseSum(20):")
    putln(csum)
    putln("primeSum(10000):")
    putln(psum)
    putln("condScore(3,5):")
    putln(cs)
    putln("loopScore():")
    putln(ls)

    val ok: bool =
        s0 == 210 &&
        csum == 1048576 &&
        psum == 5736396 &&
        cs == 129 &&
        ls == 131

    putln("all_ok:")
    putln(ok)
}
