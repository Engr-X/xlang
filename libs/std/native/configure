#!/bin/sh
set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
pwd_dir="$(pwd)"

cc="gcc"
ar="ar"
ranlib="ranlib"
cflags="-O2 -Wall -Wextra -std=c11"
target="libxlang-base"
prefix="/usr/local"
libdir=""
build_dir=""
build_dir_set="0"

usage() {
    cat <<'EOF'
Usage: ./configure [options]

Options:
  --cc=CMD                 C compiler (default: gcc)
  --ar=CMD                 archiver (default: ar)
  --ranlib=CMD             ranlib tool (default: ranlib)
  --cflags=FLAGS           extra CFLAGS (default: -O2 -Wall -Wextra -std=c11)
  --target=NAME            artifact basename (default: libxlang-base)
  --prefix=PATH            install prefix (default: /usr/local)
  --libdir=PATH            library install dir (default: PREFIX/lib)
  --build-dir=DIR          build output directory (default: build, or "." for out-of-tree)
  -h, --help               show help
EOF
}

need_value() {
    opt="$1"
    if [ "$#" -lt 2 ] || [ -z "${2:-}" ]; then
        echo "error: missing value for $opt" >&2
        exit 2
    fi
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --cc=*)
            cc="${1#*=}"
            shift
            ;;
        --cc)
            need_value "$@"
            cc="$2"
            shift 2
            ;;
        --ar=*)
            ar="${1#*=}"
            shift
            ;;
        --ar)
            need_value "$@"
            ar="$2"
            shift 2
            ;;
        --ranlib=*)
            ranlib="${1#*=}"
            shift
            ;;
        --ranlib)
            need_value "$@"
            ranlib="$2"
            shift 2
            ;;
        --cflags=*)
            cflags="${1#*=}"
            shift
            ;;
        --cflags)
            need_value "$@"
            cflags="$2"
            shift 2
            ;;
        --target=*)
            target="${1#*=}"
            shift
            ;;
        --target)
            need_value "$@"
            target="$2"
            shift 2
            ;;
        --prefix=*)
            prefix="${1#*=}"
            shift
            ;;
        --prefix)
            need_value "$@"
            prefix="$2"
            shift 2
            ;;
        --libdir=*)
            libdir="${1#*=}"
            shift
            ;;
        --libdir)
            need_value "$@"
            libdir="$2"
            shift 2
            ;;
        --build-dir=*)
            build_dir="${1#*=}"
            build_dir_set="1"
            shift
            ;;
        --build-dir)
            need_value "$@"
            build_dir="$2"
            build_dir_set="1"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "error: unknown option: $1" >&2
            usage
            exit 2
            ;;
    esac
done

if [ "$build_dir_set" = "0" ]; then
    if [ "$pwd_dir" = "$script_dir" ]; then
        build_dir="build"
    else
        build_dir="."
    fi
fi

if [ -z "$libdir" ]; then
    libdir="$prefix/lib"
fi

if [ "$pwd_dir" = "$script_dir" ]; then
    src_root="."
else
    src_root=".."
fi

config_file="config.mk"

cat > "$config_file" <<EOF
# Generated by ./configure
CC := $cc
AR := $ar
RANLIB := $ranlib
CFLAGS := $cflags
TARGET := $target
PREFIX := $prefix
LIBDIR := $libdir
BUILD_DIR := $build_dir
SRC_ROOT := $src_root
EOF

cat <<EOF
Configuration written to $config_file
  CC        = $cc
  AR        = $ar
  RANLIB    = $ranlib
  CFLAGS    = $cflags
  TARGET    = $target
  PREFIX    = $prefix
  LIBDIR    = $libdir
  BUILD_DIR = $build_dir
  SRC_ROOT  = $src_root

Next steps:
  make -j24
EOF

if [ "$pwd_dir" != "$script_dir" ]; then
    cat > Makefile <<EOF
# Generated by $0
# Out-of-tree build wrapper.
include $script_dir/Makefile
EOF
fi
